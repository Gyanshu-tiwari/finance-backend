PORT=3000
NODE_ENV=development

# JWT — REQUIRED: change to a long random string before deploying
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRES_IN=24h

# bcrypt cost factor (10 for dev, 12 for production)
BCRYPT_SALT_ROUNDS=10

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in milliseconds
RATE_LIMIT_MAX=100             # max requests per window for general API routes
AUTH_RATE_LIMIT_MAX=10         # max requests per window for auth routes

# CORS — use a specific origin in production (e.g. https://yourdomain.com)
ALLOWED_ORIGINS=*
